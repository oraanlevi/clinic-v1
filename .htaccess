RewriteEngine On

# 1) Remove explicit index.html from URLs and land on canonical domain
# /index.html -> https://www.doctoritaly24.it/
# /it/index.html -> https://www.doctoritaly24.it/it/
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[\s?]|$) [NC]
RewriteRule ^(.*/)?index\.html$ https://www.doctoritaly24.it/$1 [R=301,L]

# 2) Force canonical host + HTTPS for all other requests
# http://doctoritaly24.it/* -> https://www.doctoritaly24.it/*
# https://doctoritaly24.it/* -> https://www.doctoritaly24.it/*
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.doctoritaly24\.it$ [NC]
RewriteRule ^ https://www.doctoritaly24.it%{REQUEST_URI} [R=301,L]
